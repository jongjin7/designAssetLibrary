{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "electron"],
    "baseUrl": ".",
    "paths": {
      "@nova/ui": ["../../packages/ui/src/index.ts"],
      "@nova/ui/*": ["../../packages/ui/src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "references": []
}
