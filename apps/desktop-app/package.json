{
  "name": "nova-desktop",
  "productName": "NOVA Desktop",
  "version": "1.0.0",
  "description": "Premium Asset Management Client for Nova Project",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "node -e \"const p=require('path'),e=require('child_process');const plist=p.join(__dirname,'node_modules/electron/dist/Electron.app/Contents/Info.plist');e.execSync('/usr/libexec/PlistBuddy -c \\\"Set :CFBundleName NOVA Desktop\\\" '+plist);e.execSync('/usr/libexec/PlistBuddy -c \\\"Set :CFBundleDisplayName NOVA Desktop\\\" '+plist);\""
  },
  "dependencies": {
    "@nova/ui": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
